# UseItUp production environment reference
#
# This file documents the variables needed for a deployed UseItUp app. Do not
# copy real secret values into git.
#
# There are two different places to configure values:
#
# 1. App/public variables
#    - Use these for Expo/EAS/Vercel builds.
#    - Only EXPO_PUBLIC_* values are readable by the mobile/web app.
#
# 2. Supabase Edge Function secrets
#    - Set these in Supabase Dashboard:
#      Project Settings -> Edge Functions -> Secrets
#    - Or set them from the terminal:
#      npx supabase secrets set NAME=value
#    - These are server-side only. Never prefix private keys with EXPO_PUBLIC_.

###############################################################################
# App/public variables
###############################################################################

# Required by the Expo app and Expo web build.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

###############################################################################
# Supabase Edge Function provider selection
###############################################################################

# Recipe generation provider. Supported: gemini, openai, deepseek.
AI_PROVIDER=deepseek

# Recipe/content/term translation provider. Supported: gemini, openai, deepseek.
# If unset, generate-recipes falls back to AI_PROVIDER.
TRANSLATION_PROVIDER=deepseek

# Food image lookup provider. Supported today: pexels.
# IMAGE_PROVIDER=openai is reserved for future generated image support after
# adding Supabase Storage-backed image persistence.
IMAGE_PROVIDER=pexels

###############################################################################
# Supabase Edge Function provider resilience and usage limits
###############################################################################

# Comma-separated providers to try after the primary only for retryable failures
# such as provider downtime, rate limits, quota exhaustion, or timeout.
# Leave empty or set to none to disable fallback. Only list providers whose API
# keys are configured.
PROVIDER_FALLBACK_ORDER=gemini

# Per-provider request timeout in milliseconds. Default in code: 45000.
PROVIDER_TIMEOUT_MS=45000

# Per-user LLM limits per rolling hour. Set to 0 to disable.
# These require migration 017_create_edge_function_rate_limits.sql to be applied.
GENERATION_RATE_LIMIT_PER_HOUR=10
TRANSLATION_RATE_LIMIT_PER_HOUR=120

###############################################################################
# Gemini secrets
###############################################################################

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.5-flash
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_TEMPERATURE=0.7

###############################################################################
# OpenAI-compatible provider secrets
###############################################################################

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MAX_OUTPUT_TOKENS=8192
OPENAI_TEMPERATURE=0.7

DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MAX_OUTPUT_TOKENS=8192
DEEPSEEK_TEMPERATURE=0.7

###############################################################################
# Image lookup secrets
###############################################################################

PEXELS_API_KEY=your-pexels-api-key

###############################################################################
# Supabase server-side secret
###############################################################################

# Required by Edge Functions for translation/image/rate-limit cache reads/writes.
# This must be the service role key from Supabase API settings.
# Keep it server-only. Do not expose it to Expo, Vercel client env, or any
# EXPO_PUBLIC_* variable.
#
# Supabase Dashboard blocks custom secret names starting with SUPABASE_, so this
# project intentionally uses SERVICE_ROLE_KEY instead of SUPABASE_SERVICE_ROLE_KEY.
SERVICE_ROLE_KEY=your-service-role-key

###############################################################################
# Example CLI setup
###############################################################################

# Set values one at a time:
# npx supabase secrets set AI_PROVIDER=deepseek
# npx supabase secrets set TRANSLATION_PROVIDER=deepseek
# npx supabase secrets set IMAGE_PROVIDER=pexels
# npx supabase secrets set DEEPSEEK_API_KEY=your_deepseek_api_key
# npx supabase secrets set PEXELS_API_KEY=your_pexels_api_key
# npx supabase secrets set SERVICE_ROLE_KEY=your_service_role_key
#
# If your repo is not linked, include the project ref:
# npx supabase secrets set AI_PROVIDER=deepseek --project-ref your-project-ref
#
# After changing Edge Function source, redeploy:
# npx supabase functions deploy generate-recipes
# npx supabase functions deploy recipe-image
