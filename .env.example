# Supabase
# Copy this file to .env and replace the placeholders with your own project values.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase Edge Function secrets
AI_PROVIDER=gemini
TRANSLATION_PROVIDER=gemini
IMAGE_PROVIDER=pexels

# Comma-separated providers to try after the primary if it errors or times out
# (e.g. deepseek,gemini). Leave empty or set to "none" to disable fallback.
PROVIDER_FALLBACK_ORDER=
# Per-request timeout for AI providers, in milliseconds (default 45000). A stall
# past this triggers fallback to the next provider.
PROVIDER_TIMEOUT_MS=45000

# Per-user LLM request limits per rolling hour. Set to 0 to disable.
GENERATION_RATE_LIMIT_PER_HOUR=30
TRANSLATION_RATE_LIMIT_PER_HOUR=240
INTAKE_RATE_LIMIT_PER_HOUR=60

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.5-flash

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini

DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-flash

PEXELS_API_KEY=your-pexels-api-key
SERVICE_ROLE_KEY=your-service-role-key
