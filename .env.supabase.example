# UseItUp Supabase Edge Function secrets
#
# Copy this file to .env.supabase, fill in real values, then load every secret
# in one command:
#
#   npx supabase secrets set --env-file ./.env.supabase
#
# Or run the bootstrap script (migrations + secrets + deploy):
#
#   npm run setup:supabase
#
# Rules for this file (different from the Expo .env):
#   - Edge Function secrets ONLY. Do NOT put EXPO_PUBLIC_* values here; those are
#     app build variables that belong in .env / EAS / Vercel.
#   - Do NOT add names starting with SUPABASE_. The Supabase platform injects
#     SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY into Edge
#     Functions automatically, and the dashboard rejects custom SUPABASE_* names.
#     That is why the service role key below is named SERVICE_ROLE_KEY.
#   - Comment out (or delete) any optional line you are not using; commented
#     lines are skipped, so placeholder values are never pushed.
#
# See .env.production.example for the full annotated reference of every variable.

###############################################################################
# Provider selection (required)
###############################################################################

# Recipe generation provider. Supported: gemini, openai, deepseek.
AI_PROVIDER=deepseek

# Translation provider. If unset, falls back to AI_PROVIDER.
TRANSLATION_PROVIDER=deepseek

# Food image lookup provider. Supported today: pexels.
IMAGE_PROVIDER=pexels

###############################################################################
# Provider resilience and per-user rate limits (optional; code defaults shown)
###############################################################################

# Providers to try after the primary on retryable failures. Empty or "none" to
# disable. Only list providers whose API keys are set below.
PROVIDER_FALLBACK_ORDER=gemini

# Per-provider request timeout in milliseconds.
PROVIDER_TIMEOUT_MS=45000

# Per-user limits per rolling hour. Set to 0 to disable a limit.
GENERATION_RATE_LIMIT_PER_HOUR=30
TRANSLATION_RATE_LIMIT_PER_HOUR=240
INTAKE_RATE_LIMIT_PER_HOUR=60

###############################################################################
# Provider API keys (set the ones your AI_PROVIDER / fallback use)
###############################################################################

DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MAX_OUTPUT_TOKENS=8192
# DEEPSEEK_TEMPERATURE=0.7

GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-3.5-flash
# GEMINI_MAX_OUTPUT_TOKENS=8192
# GEMINI_TEMPERATURE=0.7

# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MAX_OUTPUT_TOKENS=8192
# OPENAI_TEMPERATURE=0.7

###############################################################################
# Image lookup (required for recipe/pantry images)
###############################################################################

PEXELS_API_KEY=your-pexels-api-key

###############################################################################
# Supabase server-side secret (required)
###############################################################################

# The service role key from Supabase: Project Settings > API. Named without the
# SUPABASE_ prefix on purpose (see rules above). Server-only; never expose it to
# the app or any EXPO_PUBLIC_* variable.
SERVICE_ROLE_KEY=your-service-role-key
